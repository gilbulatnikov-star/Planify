generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// GIL PRODUCTIONS CRM — Database Schema
// ==========================================

// ---------- CLIENTS & LEADS ----------
model Client {
  id         String   @id @default(cuid())
  name       String
  email      String?
  phone      String?
  company    String?
  website    String?
  instagram  String?
  youtube    String?
  linkedin   String?
  tiktok     String?
  notes      String?

  type       String @default("lead") // lead | client
  leadSource String? // linkedin, organic, referral, website, social, other
  leadStatus String @default("new") // new, contacted, qualified, proposal_sent, won, lost

  projects         Project[]
  interactions     Interaction[]
  invoices         Invoice[]
  quotes           Quote[]
  scheduledContent ScheduledContent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interaction {
  id       String   @id @default(cuid())
  clientId String
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type     String // call, email, meeting, note
  summary  String
  date     DateTime @default(now())

  createdAt DateTime @default(now())
}

// ---------- PROJECTS (KANBAN PIPELINE) ----------
model Project {
  id          String  @id @default(cuid())
  title       String
  description String?
  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])

  phase  String @default("pre_production") // pre_production, production, post_production, delivered
  status String @default("pitching")
  // Pre-Production:  pitching, scripting, moodboards, location_scouting
  // Production:      scheduled, shooting, wrapping
  // Post-Production: ingest_sync, rough_cut, revisions_v1, revisions_v2, color_sound, final_delivery
  // Delivered:       delivered, archived

  projectType String? // youtube, music_video, commercial, corporate, social
  budget      Float?

  shootDate   DateTime?
  deadline    DateTime?
  deliveredAt DateTime?

  tasks            Task[]
  gearAssignments  GearAssignment[]
  invoices         Invoice[]
  quotes           Quote[]
  scheduledContent ScheduledContent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  dueDate   DateTime?

  createdAt DateTime @default(now())
}

// ---------- EQUIPMENT & GEAR ----------
model Equipment {
  id            String    @id @default(cuid())
  name          String
  category      String // camera, lens, drone, lighting, audio, grip, other
  brand         String?
  model         String?
  serialNumber  String?
  purchasePrice Float?
  purchaseDate  DateTime?
  status        String    @default("available") // available, rented, in_repair, retired
  notes         String?

  gearAssignments GearAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GearAssignment {
  id           String    @id @default(cuid())
  equipmentId  String
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedDate DateTime  @default(now())
  returnDate   DateTime?
  notes        String?
}

// ---------- FINANCIALS ----------
model Quote {
  id          String @id @default(cuid())
  quoteNumber String @unique
  clientId    String
  client      Client @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  status     String   @default("draft") // draft, sent, accepted, declined
  subtotal   Float    @default(0)
  tax        Float    @default(0)
  total      Float    @default(0)
  notes      String?
  validUntil DateTime?

  items QuoteItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  total       Float
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique
  clientId      String
  client        Client @relation(fields: [clientId], references: [id])
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])

  status       String    @default("draft") // draft, sent, paid, overdue, cancelled
  subtotal     Float     @default(0)
  tax          Float     @default(0)
  total        Float     @default(0)
  dueDate      DateTime?
  paidAt       DateTime?
  notes        String?
  externalLink String?   // link to Israeli accounting software invoice

  items InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Float
  total       Float
}

model Expense {
  id          String   @id @default(cuid())
  description String
  category    String // overhead, project, gear_purchase, vehicle_travel, other
  amount      Float
  date        DateTime
  vendor      String?
  receiptUrl  String?
  notes       String?

  createdAt DateTime @default(now())
}

// ---------- CONTENT CALENDAR ----------
model ScheduledContent {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  contentType String   // client_shoot, youtube_long, short_form
  status      String   @default("planned") // planned, editing, ready, published

  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
