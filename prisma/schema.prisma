generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// GIL PRODUCTIONS CRM — Database Schema
// ==========================================

// ---------- USERS / AUTH ----------
model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String
  name                String?
  role                String?   // videographer, photographer, smm, editor, producer, agency
  primaryGoal         String?   // shoots_gear, retainer, financials, scripts
  teamSize            String?   // solo, small, studio
  onboardingCompleted Boolean   @default(false)
  locale              String    @default("he") // "he" | "en"

  // Billing & subscription
  subscriptionPlan    String    @default("FREE")    // FREE | MONTHLY | ANNUAL
  subscriptionStatus  String?                        // ACTIVE | CANCELED | PAST_DUE
  stripeCustomerId    String?                        // Stripe / Lemon Squeezy customer ID
  subscriptionEndsAt  DateTime?                      // renewal / expiry date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clients              Client[]
  contacts             Contact[]
  projects             Project[]
  scripts              Script[]
  moodboards           Moodboard[]
  assets               Asset[]
  inspirationCategories InspirationCategory[]
  inspirations         Inspiration[]
  subscriptions        Subscription[]
  travelLogs           TravelLog[]
  scheduledContents    ScheduledContent[]
  contentBoards        ContentBoard[]
  invoices             Invoice[]
  quotes               Quote[]
  expenses             Expense[]
  equipment            Equipment[]
  cheatSheets          CheatSheet[]
  quickNotes           QuickNote[]
  todos                Todo[]
  quickLinks           QuickLink[]
  gearStatuses         GearStatus[]
  feedbacks            Feedback[]
}

// ---------- CLIENTS & LEADS ----------
model Client {
  id         String   @id @default(cuid())
  name       String
  email      String?
  phone      String?
  company    String?
  website    String?
  instagram  String?
  youtube    String?
  linkedin   String?
  tiktok     String?
  notes      String?

  type       String @default("lead") // lead | client
  leadSource String? // linkedin, organic, referral, website, social, other
  leadStatus String @default("new") // new, contacted, qualified, proposal_sent, won, lost
  isActive   Boolean @default(true)  // is the client currently active
  isRetainer Boolean @default(false) // on a recurring retainer
  tags       String[] @default([])   // custom attribute tags

  userId    String?
  user      User?   @relation(fields: [userId], references: [id])

  projects         Project[]
  scripts          Script[]
  interactions     Interaction[]
  invoices         Invoice[]
  quotes           Quote[]
  scheduledContent ScheduledContent[]
  contentBoards    ContentBoard[]
  travelLogs       TravelLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interaction {
  id       String   @id @default(cuid())
  clientId String
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type     String // call, email, meeting, note
  summary  String
  date     DateTime @default(now())

  createdAt DateTime @default(now())
}

// ---------- PROJECTS (KANBAN PIPELINE) ----------
model Project {
  id          String  @id @default(cuid())
  title       String
  description String?
  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])

  phase  String @default("pre_production") // pre_production, production, post_production, delivered
  status String @default("pitching")
  // Pre-Production:  pitching, scripting, moodboards, location_scouting
  // Production:      scheduled, shooting, wrapping
  // Post-Production: ingest_sync, rough_cut, revisions_v1, revisions_v2, color_sound, final_delivery
  // Delivered:       delivered, archived

  projectType String? // youtube, music_video, commercial, corporate, social
  budget      Float?

  shootDate   DateTime?
  deadline    DateTime?
  deliveredAt DateTime?

  tasks            Task[]
  todos            Todo[]
  scripts          Script[]
  moodboards       Moodboard[]
  contacts         Contact[]
  gearAssignments  GearAssignment[]
  invoices         Invoice[]
  quotes           Quote[]
  scheduledContent ScheduledContent[]
  contentBoards    ContentBoard[]
  travelLogs       TravelLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  dueDate   DateTime?

  createdAt DateTime @default(now())
}

// ---------- EQUIPMENT & GEAR ----------
model Equipment {
  id            String    @id @default(cuid())
  name          String
  category      String // camera, lens, drone, lighting, audio, grip, other
  brand         String?
  model         String?
  serialNumber  String?
  purchasePrice Float?
  purchaseDate  DateTime?
  status        String    @default("available") // available, rented, in_repair, retired
  notes         String?

  userId        String?
  user          User?     @relation(fields: [userId], references: [id])

  gearAssignments GearAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GearAssignment {
  id           String    @id @default(cuid())
  equipmentId  String
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedDate DateTime  @default(now())
  returnDate   DateTime?
  notes        String?
}

// ---------- FINANCIALS ----------
model Quote {
  id          String @id @default(cuid())
  quoteNumber String @unique
  clientId    String
  client      Client @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  status     String   @default("draft") // draft, sent, accepted, declined
  subtotal   Float    @default(0)
  tax        Float    @default(0)
  total      Float    @default(0)
  notes      String?
  validUntil DateTime?

  items QuoteItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Int    @default(1)
  unitPrice   Float
  total       Float
}

model Invoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique
  clientId      String?
  client        Client? @relation(fields: [clientId], references: [id])
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id])
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  status       String    @default("draft") // draft, sent, paid, overdue, cancelled
  subtotal     Float     @default(0)
  tax          Float     @default(0)
  total        Float     @default(0)
  dueDate      DateTime?
  paidAt       DateTime?
  notes        String?
  externalLink String?   // link to Israeli accounting software invoice

  items InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Float
  total       Float
}

model Expense {
  id          String   @id @default(cuid())
  description String
  category    String // overhead, project, gear_purchase, vehicle_travel, other
  amount      Float
  date        DateTime
  vendor      String?
  receiptUrl  String?
  notes       String?

  userId    String?
  user      User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ---------- CONTENT CALENDAR ----------
model ContentBoard {
  id        String   @id @default(cuid())
  title     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  items     ScheduledContent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduledContent {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  contentType String   // client_shoot, youtube_long, short_form
  status      String   @default("planned") // planned, editing, ready, published, event
  isEvent     Boolean  @default(false) // show in events list

  boardId   String?
  board     ContentBoard? @relation(fields: [boardId], references: [id], onDelete: SetNull)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  userId    String?
  user      User?   @relation(fields: [userId], references: [id])

  notes String?
  color String @default("gray")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- DASHBOARD WIDGETS ----------
model QuickNote {
  id        String   @id @default(cuid())
  content   String   @default("")
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Todo {
  id          String    @id @default(cuid())
  text        String
  completed   Boolean   @default(false)
  completedAt DateTime?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model QuickLink {
  id        String   @id @default(cuid())
  name      String
  url       String
  icon      String   @default("link")
  sortOrder Int      @default(0)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GearStatus {
  id        String   @id @default(cuid())
  key       String   // sd_cards, footage, batteries
  label     String
  isReady   Boolean  @default(false)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  updatedAt DateTime @updatedAt

  @@unique([key, userId])
}

// ---------- CONTACTS / CREW ROLODEX ----------
model Contact {
  id        String   @id @default(cuid())
  name      String
  category  String   // editor, camera_op, makeup, actor, rental_house, studio
  phone     String?
  email     String?
  dailyRate Float?
  notes     String?
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- SUBSCRIPTIONS TRACKER ----------
model Subscription {
  id              String    @id @default(cuid())
  serviceName     String
  billingCycle    String    // monthly, yearly
  amount          Float
  nextBillingDate DateTime?
  status          String    @default("active") // active, cancelled
  notes           String?
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ---------- TRAVEL LOG ----------
model TravelLog {
  id          String   @id @default(cuid())
  date        DateTime
  origin      String
  destination String
  kilometers  Float
  purpose     String?
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- ASSET & LICENSE LIBRARY ----------
model Asset {
  id          String   @id @default(cuid())
  name        String
  type        String   // music, sfx, font, stock_footage
  source      String?  // artlist, envato, etc
  originalUrl String?
  licensePath String?
  notes       String?
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- INSPIRATION BOARD ----------
model InspirationCategory {
  id           String        @id @default(cuid())
  name         String
  label        String
  color        String        @default("cyan")
  sortOrder    Int           @default(0)
  userId       String?
  user         User?         @relation(fields: [userId], references: [id])
  createdAt    DateTime      @default(now())
  inspirations Inspiration[]

  @@unique([name, userId])
}

model Inspiration {
  id         String               @id @default(cuid())
  title      String
  url        String?
  category   String
  categoryId String?
  categoryRel InspirationCategory? @relation(fields: [categoryId], references: [id])
  notes      String?
  userId     String?
  user       User?               @relation(fields: [userId], references: [id])
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

// ---------- CHEAT SHEETS / SOPs ----------
model CheatSheet {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  category  String
  sortOrder Int      @default(0)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- SCRIPTS ----------
model Script {
  id           String   @id @default(cuid())
  title        String   @default("סקריפט ללא כותרת")
  content      String   @default("")
  platform     String   @default("youtube") // youtube, tiktok, instagram, podcast, commercial
  duration     String   @default("") // e.g. "60 שניות"
  notes        String   @default("")
  shotListData String   @default("[]") // JSON array of ShotItem
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  userId       String?
  user         User?   @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- FEEDBACK ----------
model Feedback {
  id        String   @id @default(cuid())
  message   String
  rating    Int?     // 1-5
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  userEmail String?
  userName  String?
  createdAt DateTime @default(now())
}

// ---------- MOODBOARDS ----------
model Moodboard {
  id        String   @id @default(cuid())
  title     String   @default("Moodboard חדש")
  nodesData String   @default("[]") // JSON array of Node objects
  edgesData String   @default("[]") // JSON array of Edge objects
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
